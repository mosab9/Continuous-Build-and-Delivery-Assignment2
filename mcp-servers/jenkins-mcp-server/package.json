{
  "name": "jenkins-mcp-server",
  "version": "1.0.0",
  "description": "MCP server for Jenkins CI/CD integration",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "npm run build:shared && tsc",
    "build:shared": "cd ../shared && npm run build",
    "start": "node dist/index.js",
    "dev": "tsc --watch",
    "clean": "rm -rf dist",
    "prepare": "npm run build"
  },
  "keywords": [
    "mcp",
    "jenkins",
    "ci-cd",
    "claude"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "typescript": "^5.3.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
